{
  "$schema": "https://mintlify.com/docs.json",
  "banner": {
    "content": "🚀 New: LFM2.5-1.2B-Instruct and LFM2.5-1.2B-Thinking are now available! [Learn more →](/docs/models/text-models)",
    "dismissible": true
  },
  "theme": "mint",
  "appearance": {
    "default": "light"
  },
  "name": "Liquid Docs",
  "description": "Documentation for Liquid AI Foundation Models (LFM)",
  "colors": {
    "primary": "#5603ad",
    "light": "#864bc4",
    "dark": "#4f46e5"
  },
  "styling": {
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "github-dark"
      }
    }
  },
  "contextual": {
    "options": [
      "copy",
      "chatgpt",
      "claude",
      "cursor",
      "vscode"
    ]
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://liquid.ai"
  },
  "navbar": {
    "links": [
      {
        "label": "Discord",
        "icon": "discord",
        "href": "https://discord.gg/DFU3WQeaYD"
      }
    ],
    "primary": {
      "type": "github",
      "href": "https://github.com/Liquid4All/cookbook"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "icon": "rocket",
            "pages": [
              "docs/getting-started/welcome",
              "docs/getting-started/connect-ai-tools"
            ]
          },
          {
            "group": "Models",
            "icon": "brain",
            "pages": [
              "docs/models/complete-library",
