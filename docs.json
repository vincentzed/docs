  "colors": {
    "primary": "#5603ad",
    "light": "#864bc4",
    "dark": "#4f46e5"
  },
  "styling": {
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "github-dark"
      }
    }
  },
  "contextual": {
    "options": [
      "copy",
      "chatgpt",
      "claude",
      "cursor",
      "vscode"
    ]
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "/lfm/getting-started/welcome"
  },
  "navbar": {
