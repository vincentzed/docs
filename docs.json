      {
        "tab": "Examples",
        "groups": [
          {
            "group": "Get Started",
            "icon": "rocket",
            "pages": [
              "examples/index",
              "docs/getting-started/connect-ai-tools"
            ]
          },
          {
            "group": "Laptop Examples",
            "icon": "laptop",
            "pages": [
              "examples/laptop-examples/invoice-extractor-tool-with-liquid-nanos",
